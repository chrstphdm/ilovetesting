nextflow_process {
    name "Test FASTQC"
    script "../../pipelines/minimal/modules/fastqc.nf"
    process "FASTQC"

    test("reads valides → HTML et stats produits") {
        when {
            process {
                input[0] = [
                    [id: "sample1", single_end: true],
                    file("${projectDir}/../data/sample.fastq")
                ]
            }
        }
        then {
            assert process.success
            assert process.out.html.size() == 1
            assert process.out.stats.size() == 1

            def html_file = process.out.html[0][1]
            assert html_file.name.endsWith(".html")
            assert html_file.text.contains("sample1")

            assert snapshot(process.out.stats).match()
        }
    }

    test("fichier vide → process échoue") {
        when {
            process {
                input[0] = [
                    [id: "empty_sample", single_end: true],
                    file("${projectDir}/../data/empty.fastq")
                ]
            }
        }
        then {
            assert process.failed
        }
    }
}
