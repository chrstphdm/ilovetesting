// Template nf-test — process
// Copier dans modules/<nom_module>.nf.test

nextflow_process {
    name "Test <NOM_PROCESS>"
    script "modules/<nom_module>.nf"
    process "<NOM_PROCESS>"

    test("<description du cas nominal>") {
        when {
            process {
                input[0] = [
                    [id: "sample1"],
                    file("${projectDir}/../../data/<fichier_test>")
                ]
            }
        }
        then {
            assert process.success
            assert process.out.<canal_sortie>.size() == 1
            assert snapshot(process.out).match()
        }
    }

    test("<description du cas d'erreur>") {
        when {
            process {
                input[0] = [
                    [id: "bad_sample"],
                    file("${projectDir}/../../data/empty.fastq")
                ]
            }
        }
        then {
            assert process.failed
        }
    }
}

// ─────────────────────────────────────────────────────────────────────────────
// Template nf-test — workflow

nextflow_workflow {
    name "Test <NOM_WORKFLOW>"
    script "workflows/<nom_workflow>.nf"
    workflow "<NOM_WORKFLOW>"

    test("<description>") {
        when {
            workflow {
                input[0] = Channel.of([
                    [id: "sample1"],
                    file("${projectDir}/../../data/<fichier_test>")
                ])
            }
        }
        then {
            assert workflow.success
            assert workflow.out.<canal>.size() == 1
            assert snapshot(workflow.out.<canal>).match()
        }
    }
}
