params {
    input  = null
    outdir = "results"
    min_length = 20
    min_quality = 20
}

profiles {
    test {
        params.input     = "${projectDir}/../../data/sample.fastq"
        params.outdir    = "${projectDir}/results_test"
        params.min_length  = 20
        params.min_quality = 20

        process.resourceLimits = [
            cpus: 2, memory: "2.GB", time: "30.m"
        ]
    }
}

process {
    publishDir = [
        path: { "${params.outdir}/${task.process.tokenize(':')[-1].toLowerCase()}" },
        mode: "copy"
    ]
}
